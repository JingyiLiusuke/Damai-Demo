    <string name="accessibility_service_name">大麦自动化助手</string>
    <string name="accessibility_service_description">在用户手动控制下，通过无障碍节点、手势和截图执行本地大麦操作流程。</string>

    <string name="usage_summary">使用前请先登录大麦并进入目标项目页面，完成三个阶段的区域校准，然后设置开售时间并点击“开始待命”。运行期间请保持手机亮屏、解锁且大麦位于前台。</string>
    <string name="section_time">一、时间设置</string>
    <string name="target_time_label">目标开售时间（格式：yyyy-MM-dd HH:mm:ss.SSS）</string>
    <string name="pre_trigger_offset_hint">提前触发时间（毫秒，例如 100）</string>
    <string name="test_now_label">立即测试模式（约 500 毫秒后触发，仅用于安全测试）</string>
    <string name="section_regions">二、阶段点击区域</string>
    <string name="regions_help">阶段一：立即预定；阶段二：确定票价；阶段三：立即提交。点击“校准阶段区域”重新截图并框选按钮。</string>
    <string name="section_detection">三、检测设置</string>
